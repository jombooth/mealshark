{
  "manifest_version": 3,
  "name": "Mealshark",
  "description": "Mealshark finds the best deals on MealPal! Discover newly added meals, sort by % off, and see what you're paying for each meal.",
  "version": "0.1.0",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "Mealshark",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    },
    "default_popup": "src/popup.html"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://secure.mealpal.com/*"],
  "content_scripts": [
    {
      "matches": ["https://secure.mealpal.com/*"],
      "js": ["src/page-hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://secure.mealpal.com/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_start"
    }
  ]
}
