{
  "manifest_version": 3,
  "name": "Mealshark",
  "description": "A Chrome extension layer for mealpal.com.",
  "version": "0.1.0",
  "action": {
    "default_title": "Mealshark",
    "default_popup": "src/popup.html"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://mealpal.com/*", "https://*.mealpal.com/*"],
  "content_scripts": [
    {
      "matches": ["https://mealpal.com/*", "https://*.mealpal.com/*"],
      "js": ["src/page-hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://mealpal.com/*", "https://*.mealpal.com/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_start"
    }
  ]
}
